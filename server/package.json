{
  "name": "queuing-system-simulation-gui",
  "author": "Seif Rashwan",
  "license": "MIT",
  "version": "1.0.0",
  "description": "Queuing system simulation with c++ backend and web GUI.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "g++ -std=c++23 -I../include ../src/CustomerType.cpp ../src/ServerType.cpp ../src/ServerListType.cpp ../src/WaitingCustomerQueue.cpp ../src/WebSimulation.cpp -o ../build/simulation.exe",
    "build-debug": "g++ -g -O0 -std=c++23 -I../include ../src/CustomerType.cpp ../src/ServerType.cpp ../src/ServerListType.cpp ../src/WaitingCustomerQueue.cpp ../src/WebSimulation.cpp -o ../build/simulation-debug.exe"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "queuing",
    "simulation",
    "cpp",
    "web",
    "gui"
  ]
}
